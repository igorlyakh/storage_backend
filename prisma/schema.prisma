generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STORE // магазин
  WAREHOUSE // марлог
  ADMIN // администратор
}

enum PackageType {
  PALLET
  BOX
  PACKAGE
  PIECE
}

enum AdminScope {
  NCG // Цур
  ADMINISTRATIVE // Света
}

enum OrderStatus {
  NEW // создан магазином
  IN_PROGRESS // в работе в марлоге
  SENT // отправлен
  COMPLETED // закрыт
  BACKORDER // товары, которых не было, но скоро будут
}

enum WarehouseRequestStatus {
  NEW
  APPROVED
  SENT
  COMPLETED
}

model User {
  id           String  @id @default(uuid(7))
  username     String  @unique
  password     String
  role         Role
  isActive     Boolean @default(true)
  refreshToken String?

  // магазин
  storeId Int?
  store   Store? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // администратор
  adminScopes AdminScope[]

  // склад
  warehouseRequests WarehouseRequest[] @relation("WarehouseCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categories {
  id   String @id @default(uuid(7))
  name String @unique

  createdAt DateTime @default(now())

  products Product[]
}

model Brand {
  id   String @id @default(uuid(7))
  name String @unique

  stores   Store[]
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id   Int    @id @default(autoincrement())
  name String @unique

  users  User[]
  orders Order[]

  brands Brand[]

  createdAt DateTime @default(now())
}

//! PRODUCTS & STOCK

model Product {
  id            String      @id @default(uuid(7))
  article       String      @default("000000-00")
  name          String      @unique
  category      Categories? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  tag           AdminScope
  isEnabled     Boolean     @default(true)
  limitPerOrder Int?

  packageType     PackageType @default(PIECE)
  itemsPerPackage Int         @default(0)

  stock        WarehouseStock?
  orderItems   OrderItem[]
  requestItems WarehouseRequestItem[]
  brands       Brand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarehouseStock {
  id           String @id @default(uuid(7))
  productId    String @unique
  packageCount Int    @default(0) // кол-во упаковок
  quantity     Int // текущий остаток

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

// STORE -> WAREHOUSE ORDERS

model Order {
  id      String @id @default(uuid(7))
  storeId Int
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name    String

  status OrderStatus @default(NEW)

  items OrderItem[]

  customRequest String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String @id @default(uuid(7))
  orderId   String
  productId String

  requestedQty Int // запрос магазина
  shippedQty   Int? // фактически отправлено складом

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// WAREHOUSE -> ADMIN REQUESTS (REPLENISHMENT)

model WarehouseRequest {
  id       String                 @id @default(uuid(7))
  category AdminScope
  status   WarehouseRequestStatus @default(NEW)

  items WarehouseRequestItem[]

  createdBy String
  creator   User   @relation("WarehouseCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarehouseRequestItem {
  id        String @id @default(uuid(7))
  requestId String
  productId String
  quantity  Int

  packageType PackageType @default(PIECE)

  request WarehouseRequest @relation(fields: [requestId], references: [id])
  product Product          @relation(fields: [productId], references: [id])
}
