generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STORE
  WAREHOUSE
  ADMIN
}

enum PackageType {
  PALLET
  BOX
  PACKAGE
  PIECE
}

enum AdminScope {
  NCG
  ADMINISTRATIVE
  RFID
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  SENT
  COMPLETED
  BACKORDER
}

enum WarehouseRequestStatus {
  NEW
  APPROVED
  SENT
  COMPLETED
}

enum Language {
  EN
  RU
  HE
}

model User {
  id           String   @id @default(uuid(7))
  username     String   @unique
  password     String
  role         Role
  isActive     Boolean  @default(true)
  refreshToken String?
  language     Language @default(EN)

  storeId Int?
  store   Store? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  adminScopes AdminScope[]

  warehouseRequests WarehouseRequest[] @relation("WarehouseCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categories {
  id    String @id @default(uuid(7))
  name  String @unique
  order Int    @default(0)

  createdAt DateTime @default(now())

  products Product[]
}

model Brand {
  id   String @id @default(uuid(7))
  name String @unique

  stores   Store[]
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id   Int    @id @default(autoincrement())
  name String @unique

  users  User[]
  orders Order[]

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  createdAt DateTime @default(now())
}

model Product {
  id            String      @id @default(uuid(7))
  article       String      @default("000000-00")
  name          String      @unique
  category      Categories? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  tag           AdminScope
  isEnabled     Boolean     @default(true)
  limitPerOrder Int?
  order         Int         @default(0)
  imageUrl      String?

  packageType     PackageType @default(PIECE)
  itemsPerPackage Int         @default(0)

  stocks       WarehouseStock[]
  orderItems   OrderItem[]
  requestItems WarehouseRequestItem[]
  brands       Brand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Warehouse {
  id        String  @id @default(uuid(7))
  name      String  @unique
  isDefault Boolean @default(false)

  stocks         WarehouseStock[]
  sourceRequests WarehouseRequest[] @relation("RequestSourceWarehouse")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarehouseStock {
  id           String @id @default(uuid(7))
  productId    String
  warehouseId  String
  packageCount Int    @default(0)
  quantity     Int

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([productId, warehouseId])
}

model Order {
  id      String @id @default(uuid(7))
  storeId Int
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name    String

  status OrderStatus @default(NEW)

  items OrderItem[]

  customRequest String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String @id @default(uuid(7))
  orderId   String
  productId String

  requestedQty Int
  shippedQty   Int?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model WarehouseRequest {
  id       String                 @id @default(uuid(7))
  category AdminScope
  status   WarehouseRequestStatus @default(NEW)

  items WarehouseRequestItem[]

  sourceWarehouseId String?
  sourceWarehouse   Warehouse? @relation("RequestSourceWarehouse", fields: [sourceWarehouseId], references: [id], onDelete: SetNull)

  createdBy String
  creator   User   @relation("WarehouseCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarehouseRequestItem {
  id        String @id @default(uuid(7))
  requestId String
  productId String
  quantity  Int

  packageType PackageType @default(PIECE)

  request WarehouseRequest @relation(fields: [requestId], references: [id])
  product Product          @relation(fields: [productId], references: [id])
}
