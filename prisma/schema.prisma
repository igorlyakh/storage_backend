generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STORE // магазин
  WAREHOUSE // марлог
  ADMIN // администратор
}

enum AdminScope {
  NCG // Цур
  ADMINISTRATIVE // Света
}

enum OrderStatus {
  NEW // создан магазином
  IN_PROGRESS // в работе в марлоге
  SENT // отправлен
  COMPLETED // закрыт
}

enum WarehouseRequestStatus {
  NEW
  APPROVED
  SENT
  COMPLETED
}

model User {
  id          String  @id @default(uuid())
  username    String  @unique
  password    String
  role        Role
  isActive    Boolean @default(true)
  accessToken String?

  // магазин
  storeId Int?
  store   Store? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // администратор
  adminScopes AdminScope[]

  // склад
  warehouseRequests WarehouseRequest[] @relation("WarehouseCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categories {
  id   String @id @default(uuid())
  name String @unique

  createdAt DateTime @default(now())

  products Product[]
}

model Brand {
  id   String @id @default(uuid())
  name String @unique

  stores   Store[]
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id   Int    @id @default(autoincrement())
  name String @unique

  users  User[]
  orders Order[]

  brands Brand[]

  createdAt DateTime @default(now())
}

//! PRODUCTS & STOCK

model Product {
  id            String      @id @default(uuid())
  name          String      @unique
  category      Categories? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  tag           AdminScope
  isEnabled     Boolean     @default(true)
  limitPerOrder Int?

  stock        WarehouseStock?
  orderItems   OrderItem[]
  requestItems WarehouseRequestItem[]
  brands       Brand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarehouseStock {
  id        String @id @default(uuid())
  productId String @unique
  quantity  Int // текущий остаток

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

// STORE -> WAREHOUSE ORDERS

model Order {
  id      String @id @default(uuid())
  storeId Int
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  status OrderStatus @default(NEW)

  items OrderItem[]

  customRequest String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String

  requestedQty Int // запрос магазина
  shippedQty   Int? // фактически отправлено складом

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// WAREHOUSE -> ADMIN REQUESTS (REPLENISHMENT)

model WarehouseRequest {
  id       String                 @id @default(uuid())
  category AdminScope
  status   WarehouseRequestStatus @default(NEW)

  items WarehouseRequestItem[]

  createdBy String
  creator   User   @relation("WarehouseCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarehouseRequestItem {
  id        String @id @default(uuid())
  requestId String
  productId String
  quantity  Int

  request WarehouseRequest @relation(fields: [requestId], references: [id])
  product Product          @relation(fields: [productId], references: [id])
}
